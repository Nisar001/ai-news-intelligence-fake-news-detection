APP_NAME=AI News Intelligence Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_API_V1_PREFIX=/api/v1
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_INTERNAL_API_KEYS=local-dev-key
APP_RATE_LIMIT=60/minute
APP_HF_MODEL_NAME=your-org/roberta-fake-news
APP_HF_MODEL_REVISION=main
APP_HF_USE_GPU=false
APP_MODEL_LABEL_FAKE=FAKE
APP_MODEL_LABEL_REAL=REAL
APP_MODEL_LOW_CONFIDENCE_THRESHOLD=0.55
APP_MODEL_UNCERTAIN_MARGIN=0.15
APP_MODEL_MAX_TOKENS=1024
APP_GEMINI_API_KEY=replace-me
APP_GEMINI_PRIMARY_MODEL=gemini-2.0-flash
APP_GEMINI_FALLBACK_MODEL=gemini-2.0-flash
APP_GEMINI_TIMEOUT_SECONDS=20
APP_GEMINI_MAX_RETRIES=3
APP_GEMINI_TEMPERATURE=0.2
APP_REDIS_URL=redis://redis:6379/0
APP_DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/ai_news
APP_CELERY_BROKER_URL=redis://redis:6379/1
APP_CELERY_RESULT_BACKEND=redis://redis:6379/2
APP_CACHE_TTL_SECONDS=3600
APP_SENTRY_DSN=
APP_PROMETHEUS_ENABLED=true
